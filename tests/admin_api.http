### 9.1 DELETE /admin/jelentkezok/:jid - Jelentkező törlése - Sikeres
# Töröljük a jid=21 jelentkezőt (Kovács Zsolt a tesztadatokból)
# @name deleteAdminJelentkezoSikeres
# Elvárt eredmény:
# Status: 200 OK
# Body: JSON objektum
#       { "message": "Jelentkező sikeresen törölve.", "changes": 1 }
DELETE {{baseUrl}}/admin/jelentkezok/21
Authorization: Bearer {{authToken}}
Content-Type: application/json

### 9.2 DELETE /admin/jelentkezok/:jid - Jelentkező törlése - Hiba: Nem létező jelentkező
# @name deleteAdminJelentkezoNemLetezo
# Elvárt eredmény:
# Status: 404 Not Found
# Body: JSON objektum
#       { "message": "Jelentkező nem található." }
DELETE {{baseUrl}}/admin/jelentkezok/9997
Authorization: Bearer {{authToken}}
Content-Type: application/json

### 10.1 DELETE /admin/csoportok/:csid - Csoport törlése - Sikeres (nincs rá hivatkozás)
# Az újonnan létrehozott és módosított {{ujCsoportId}} csoportot töröljük.
# @name deleteAdminCsoportSikeres
# Elvárt eredmény:
# Status: 200 OK
# Body: JSON objektum
#       { "message": "Csoport sikeresen törölve.", "changes": 1 }
DELETE {{baseUrl}}/admin/csoportok/{{ujCsoportId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### 10.2 DELETE /admin/csoportok/:csid - Csoport törlése - Hiba: Nem létező csoport
# @name deleteAdminCsoportNemLetezo
# Elvárt eredmény:
# Status: 404 Not Found
# Body: JSON objektum
#       { "message": "Csoport nem található." }
DELETE {{baseUrl}}/admin/csoportok/9996
Authorization: Bearer {{authToken}}
Content-Type: application/json

### 10.3 DELETE /admin/csoportok/:csid - Csoport törlése - Hiba: Nem törölhető (van hozzá rendelt jelentkező)
# csid=1 csoporthoz vannak jelentkezők a tesztadatok szerint.
# @name deleteAdminCsoportNemTorolheto
# Elvárt eredmény:
# Status: 400 Bad Request
# Body: JSON objektum
#       { "message": "A csoport nem törölhető, mert vannak hozzá rendelt jelentkezők." }
DELETE {{baseUrl}}/admin/csoportok/1
Authorization: Bearer {{authToken}}
Content-Type: application/json
